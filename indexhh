    <script>
        function setLanguage(lang) {
            // Traduz elementos soltos que possuem a classe i18n
            document.querySelectorAll('.i18n').forEach(el => {
                if (el.getAttribute(`data-${lang}`)) el.innerHTML = el.getAttribute(`data-${lang}`);
            });
            
            // Alterna a classe no body para esconder/mostrar as seções inteiras
            document.body.className = `lang-${lang}`;
            
            // Estiliza o botão ativo no topo
            document.querySelectorAll('.lang-btn').forEach(btn => btn.classList.remove('active'));
            document.getElementById(`btn-${lang}`).classList.add('active');
            
            // Salva a preferência no navegador do usuário
            localStorage.setItem('oracleLanguage', lang);
        }

        document.addEventListener('DOMContentLoaded', () => {
            const savedLang = localStorage.getItem('oracleLanguage');
            const userLang = navigator.language || navigator.userLanguage;
            if (savedLang) {
                setLanguage(savedLang);
            } else if (userLang.includes('en')) {
                setLanguage('en');
            } else {
                setLanguage('pt');
            }
        });
    </script>
